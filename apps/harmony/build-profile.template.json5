{
  // Copy this file to `build-profile.json5` and fill in your own signing material.
  // The real build-profile.json5 is git-ignored to keep signing credentials out of the repo.
  "app": {
    "signingConfigs": [
      {
        "name": "default",
        "type": "OpenHarmony",
        "material": {
          "storeFile": "./signing/openharmony/your-keystore.p12",
          "storePassword": "<YOUR_STORE_PASSWORD>",
          "keyAlias": "openharmony application release",
          "keyPassword": "<YOUR_KEY_PASSWORD>",
          "signAlg": "SHA256withECDSA",
          "profile": "./signing/openharmony/your-debug-profile.p7b",
          "certpath": "./signing/openharmony/your-cert-chain.cer"
        }
      }
    ],
    "compileSdkVersion": 9,
    "compatibleSdkVersion": 9,
    "products": [
      {
        "name": "default",
        "signingConfig": "default"
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}
