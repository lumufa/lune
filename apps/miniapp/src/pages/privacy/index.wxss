/* Privacy page — visual aligned to mobile (apps/mobile/app/privacy.tsx). */
/* Mobile px → miniapp rpx: ×2. 1px borders kept as 1rpx (smallest miniapp can render). */

.privacy-screen {
  padding: 32rpx 40rpx 120rpx;
  gap: 32rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
}

.privacy-page-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
  color: var(--ink);
}

.lang-btn {
  min-width: 96rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* ── Cards (override global .card to match mobile) ── */
.privacy-screen .card {
  padding: 32rpx;
  border-radius: 40rpx;
  border: 1rpx solid var(--line-strong);
  gap: 24rpx;
  display: flex;
  flex-direction: column;
}

/* ── Setting list ── */
.setting-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider);
}

.setting-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.setting-item:first-child {
  padding-top: 0;
}

.setting-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.setting-title {
  display: block;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}

/* ── Export card primary button ── */
.access-btn {
  width: 100%;
  min-height: 96rpx;
  line-height: 96rpx;
  border-radius: 32rpx;
  background: var(--ink);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
}

.access-btn::after { border: none; }

.export-panel {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: var(--pink-mist);
}

.preview-title {
  display: block;
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
}

.preview-line {
  display: block;
  color: var(--ink-secondary);
  font-size: 24rpx;
  line-height: 1.5;
}

/* ── Danger card buttons ── */
.compact-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin: 0;
}

.compact-actions .ghost-btn-strong {
  flex: 1;
  min-height: 88rpx;
  line-height: 88rpx;
  border-radius: 32rpx;
  border: 1rpx solid var(--line-strong);
  background: var(--surface);
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;
}

.compact-actions .danger-btn-soft {
  flex: 1;
  min-height: 88rpx;
  line-height: 88rpx;
  border-radius: 32rpx;
  background: var(--pink-mist);
  border: 1rpx solid var(--pink-border);
  color: var(--accent-deep);
  font-size: 26rpx;
  font-weight: 700;
  padding: 0;
}

.compact-actions .danger-btn-soft::after { border: none; }
.compact-actions .ghost-btn-strong::after { border: none; }

/* ── Action list ── */
.action-panel {
  display: flex;
  flex-direction: column;
}

.action-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.action-item:first-child {
  padding-top: 0;
}

.action-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.action-title {
  display: block;
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
}

.action-meta {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-state {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}
