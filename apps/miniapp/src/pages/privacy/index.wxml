<view class="screen privacy-screen">
  <view class="toolbar">
    <text class="page-title privacy-page-title">{{copy.heroEyebrow}}</text>
    <button class="ghost-btn lang-btn" size="mini" bindtap="toggleLanguage">{{copy.languageButtonLabel}}</button>
  </view>

  <view class="card setting-card">
    <text class="section-title">{{copy.settingsSectionTitle}}</text>
    <view class="setting-list">
      <view class="setting-item" wx:for="{{settingViews}}" wx:key="type">
        <view class="setting-copy">
          <text class="setting-title">{{item.title}}</text>
        </view>
        <switch
          checked="{{item.enabled}}"
          data-type="{{item.type}}"
          bindchange="toggleSetting"
          color="#FF4D6A"
          disabled="{{isToggling || isDeleting}}"
        />
      </view>
    </view>
  </view>

  <view class="card export-card">
    <text class="section-title">{{copy.exportSectionTitle}}</text>
    <button class="primary-btn access-btn" bindtap="exportData">{{copy.accessLogLabel}}</button>
    <view class="export-panel" wx:if="{{exportBundle}}">
      <text class="preview-title">{{copy.exportPreviewTitle}}</text>
      <text class="preview-line">{{copy.exportPreviewPrefix}} {{exportBundle.exportedAt}}</text>
      <text class="preview-line">{{exportBundle.cycles.length}} {{copy.exportPreviewUnit}}</text>
    </view>
  </view>

  <view class="card danger-card">
    <text class="section-title">{{copy.dangerSectionTitle}}</text>
    <view class="button-row compact-actions">
      <button class="ghost-btn ghost-btn-strong" bindtap="withdrawSensitiveConsent">{{copy.withdrawLabel}}</button>
      <button class="danger-btn danger-btn-soft" loading="{{isDeleting}}" bindtap="deleteAccount">{{copy.deleteLabel}}</button>
    </view>
  </view>

  <view class="card action-card">
    <text class="section-title">{{copy.actionSectionTitle}}</text>
    <view class="action-panel" wx:if="{{actionViews.length}}">
      <view class="action-item" wx:for="{{actionViews}}" wx:key="id">
        <text class="action-title">{{item.typeLabel}}</text>
        <text class="action-meta">{{item.metaLabel}}</text>
      </view>
    </view>
    <view class="empty-state" wx:else>
      {{copy.actionEmpty}}
    </view>
  </view>
</view>
