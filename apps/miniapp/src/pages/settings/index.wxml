<view class="screen settings-screen">
  <text class="page-title">{{copy.title}}</text>

  <!-- Cycle length: auto-only (没记录时空态) -->
  <view class="param-card">
    <text class="param-label">{{copy.cycleLengthLabel}}</text>
    <block wx:if="{{isAutoComputed}}">
      <view class="param-auto-row">
        <text class="param-auto-value">{{cycleLength}}</text>
        <text class="param-auto-unit">{{copy.dayUnit}}</text>
      </view>
      <view class="auto-badge">
        <text class="auto-badge-glyph">✦</text>
        <text class="auto-badge-text">{{copy.autoBadgePrefix}}{{recordCount}}{{copy.autoBadgeSuffix}}</text>
      </view>
    </block>
    <block wx:else>
      <view class="param-auto-row">
        <text class="param-auto-value param-auto-value-pending">—</text>
        <text class="param-auto-unit">{{copy.dayUnit}}</text>
      </view>
      <text class="param-hint">{{copy.pendingHint}}</text>
    </block>
  </view>

  <!-- Period length: auto-only -->
  <view class="param-card">
    <text class="param-label">{{copy.periodLengthLabel}}</text>
    <block wx:if="{{isAutoComputed}}">
      <view class="param-auto-row">
        <text class="param-auto-value">{{periodLength}}</text>
        <text class="param-auto-unit">{{copy.dayUnit}}</text>
      </view>
      <view class="auto-badge">
        <text class="auto-badge-glyph">✦</text>
        <text class="auto-badge-text">{{copy.autoBadgePrefix}}{{recordCount}}{{copy.autoBadgeSuffix}}</text>
      </view>
    </block>
    <block wx:else>
      <view class="param-auto-row">
        <text class="param-auto-value param-auto-value-pending">—</text>
        <text class="param-auto-unit">{{copy.dayUnit}}</text>
      </view>
      <text class="param-hint">{{copy.pendingHint}}</text>
    </block>
  </view>

  <!-- Section: Reminders summary (对标 mobile reminders & quiet hours summary card) -->
  <view class="summary-card" bindtap="openReminders">
    <view class="summary-head">
      <text class="summary-title">{{copy.reminderSummaryTitle}}</text>
      <view class="summary-arrow">
        <text class="summary-arrow-glyph">›</text>
      </view>
    </view>
    <text class="summary-body">{{reminderSummaryText}}</text>
  </view>

  <!-- Section: Trends summary -->
  <view class="summary-card" bindtap="openTrends">
    <view class="summary-head">
      <text class="summary-title">{{copy.trendsTitle}}</text>
      <view class="summary-arrow">
        <text class="summary-arrow-glyph">›</text>
      </view>
    </view>
  </view>

  <!-- Section: Privacy & data -->
  <view class="privacy-card">
    <view class="privacy-head">
      <text class="privacy-title">{{copy.privacyTitle}}</text>
      <view class="privacy-arrow" bindtap="openPrivacy">
        <text class="privacy-arrow-glyph">›</text>
      </view>
    </view>
    <view class="privacy-actions">
      <button class="privacy-btn privacy-btn-primary" bindtap="exportData">{{copy.exportLabel}}</button>
      <button class="privacy-btn privacy-btn-danger" bindtap="deleteAccount">{{copy.deleteLabel}}</button>
    </view>
  </view>
</view>
