.settings-screen {
  gap: 24rpx;
}

/* ── Param card (对标 mobile stepperCard / autoCard) ── */
.param-card {
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid var(--line-strong);
  box-shadow: var(--shadow-card);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.param-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.param-label {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 700;
}

.param-value {
  color: var(--accent);
  font-size: 40rpx;
  font-weight: 700;
}

/* manual stepper row */
.param-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.param-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--chip-idle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.param-btn:active {
  background: var(--pink-pale);
}

.param-btn-glyph {
  color: var(--ink);
  font-size: 52rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.param-track {
  flex: 1;
  height: 20rpx;
  border-radius: 9999rpx;
  background: var(--chip-idle);
  position: relative;
}

.param-track-fill {
  height: 100%;
  border-radius: 9999rpx;
  background: var(--accent);
}

.param-track-thumb {
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: var(--accent);
  top: -14rpx;
  margin-left: -24rpx;
  border: 6rpx solid #FFFFFF;
  box-shadow: 0rpx 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.param-hint {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
}

/* auto mode */
.param-auto-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 12rpx;
}

.param-auto-value {
  color: var(--accent);
  font-size: 64rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.param-auto-value-pending {
  color: var(--muted-soft);
}

.param-auto-unit {
  color: var(--ink-body);
  font-size: 28rpx;
  font-weight: 500;
}

.auto-badge {
  align-self: flex-start;
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: var(--pink-mist);
  border: 1rpx solid var(--pink-border);
}

.auto-badge-glyph {
  color: var(--accent-deep);
  font-size: 22rpx;
  line-height: 22rpx;
}

.auto-badge-text {
  color: var(--accent-deep);
  font-size: 22rpx;
  font-weight: 600;
}

/* ── Reminders summary card (对标 mobile 折叠条目) ── */
.summary-card {
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid var(--line-strong);
  box-shadow: var(--shadow-card);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}

.summary-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-title {
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
}

.summary-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-arrow-glyph {
  color: var(--muted);
  font-size: 40rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.summary-body {
  color: var(--ink-body);
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 500;
}

/* ── Privacy card (对标 mobile settings 隐私卡) ── */
.privacy-card {
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid var(--line-strong);
  box-shadow: var(--shadow-card);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 8rpx;
  margin-bottom: 48rpx;
}

.privacy-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.privacy-title {
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
}

.privacy-arrow {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-arrow:active {
  background: var(--surface-sunken);
}

.privacy-arrow-glyph {
  color: var(--muted);
  font-size: 40rpx;
  line-height: 40rpx;
  font-weight: 500;
}

.privacy-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.privacy-btn {
  flex: 1;
  min-height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn-primary {
  background: var(--ink);
  color: #FFFFFF;
}

.privacy-btn-danger {
  background: var(--pink-mist);
  color: var(--accent-deep);
  border: 1rpx solid var(--pink-border);
}
