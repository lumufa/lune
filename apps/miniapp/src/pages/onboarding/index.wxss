.onboarding-screen {
  background: var(--flo-canvas);
  gap: 28rpx;
  padding-bottom: 200rpx;
}

.lang-btn {
  min-width: 96rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* ── Hero panel ── */
.hero-panel {
  position: relative;
  border-radius: 56rpx;
  overflow: hidden;
  background: var(--flo-hero);
  padding: 56rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.hero-glow-a {
  position: absolute;
  width: 640rpx;
  height: 640rpx;
  border-radius: 320rpx;
  background: rgba(255, 255, 255, 0.28);
  top: -180rpx;
  left: -200rpx;
}

.hero-glow-b {
  position: absolute;
  width: 480rpx;
  height: 480rpx;
  border-radius: 240rpx;
  background: rgba(255, 255, 255, 0.36);
  bottom: -120rpx;
  right: -140rpx;
}

.brand-icon {
  position: relative;
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 8rpx 32rpx rgba(32, 32, 40, 0.08);
}

.brand-name {
  position: relative;
  color: var(--flo-pink);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.hero-panel .hero-title {
  position: relative;
  color: var(--flo-ink);
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
  text-align: center;
  margin-top: 0;
}

.hero-panel .hero-subtitle {
  position: relative;
  color: #616270;
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
  margin-top: 8rpx;
  padding: 0 12rpx;
}

/* ── Consent cards ── */
.consent-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 40rpx;
  background: #ffffff;
  border: 2rpx solid var(--flo-border);
}

.consent-card-muted {
  opacity: 0.7;
}

.consent-icon-wrap {
  flex-shrink: 0;
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.privacy-icon-bg {
  background: #FFF1F5;
}

.health-icon-bg {
  background: #EFF6FF;
}

.sync-icon-bg {
  background: #F0FDF9;
}

.consent-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.consent-title {
  color: var(--flo-ink);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.consent-detail {
  color: var(--flo-muted);
  font-size: 24rpx;
  line-height: 1.5;
}

/* Sync badge */
.sync-badge {
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F7;
}

.sync-badge-ok {
  background: rgba(255, 91, 141, 0.12);
}

.sync-badge-dot {
  font-size: 28rpx;
  color: #B0B1BB;
}

.sync-badge-ok .sync-badge-dot {
  color: var(--flo-pink);
  font-weight: 700;
}

/* ── CTA footer ── */
.cta-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, var(--flo-canvas) 60%, transparent);
  z-index: 10;
}

.cta-btn {
  width: 100%;
  min-height: 112rpx;
  border-radius: 36rpx;
  background: #111217;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 112rpx;
}

.cta-btn::after {
  border: none;
}

.cta-btn-disabled {
  background: #C8C9CE;
  color: rgba(255, 255, 255, 0.7);
}
