/* ── Tokens ── */
page {
  --ob-pink: #FF4D6A;
  --ob-pink-soft: #FF6B82;
  --ob-pink-pale: #FFE8EC;
  --ob-pink-mist: #FFF5F7;
  --ob-ink: #1E1E2C;
  --ob-sub: #8C8C9A;
  --ob-muted: #C4C4CE;
  --ob-bg: #FBF8F9;
  --ob-white: #FFFFFF;
  --ob-divider: rgba(0,0,0,0.04);
}

.screen {
  position: relative;
  min-height: 100vh;
  background: var(--ob-bg);
  overflow: hidden;
  padding: 0;
  display: block;
}

/* ── Animations ── */
@keyframes slideUp {
  from { opacity: 0; transform: translateY(56rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes scaleUp {
  from { opacity: 0; transform: scale(0.88); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes slideCard {
  from { opacity: 0; transform: translateY(36rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes ringPulse {
  0%, 100% { transform: translate(-50%,-50%) scale(1); opacity: 0.18; }
  50%      { transform: translate(-50%,-50%) scale(1.06); opacity: 0.3; }
}
@keyframes dotOrbit {
  0%   { transform: rotate(0deg) translateX(104rpx) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(104rpx) rotate(-360deg); }
}
@keyframes shimmer {
  0%   { left: -80%; }
  100% { left: 180%; }
}

.au { animation: slideUp 0.65s cubic-bezier(0.16,1,0.3,1) forwards; opacity: 0; }
.af { animation: fadeIn 0.7s ease forwards; opacity: 0; }
.as { animation: scaleUp 0.65s cubic-bezier(0.16,1,0.3,1) forwards; opacity: 0; }
.ac { animation: slideCard 0.55s cubic-bezier(0.16,1,0.3,1) forwards; opacity: 0; }

.delay-1 { animation-delay: 0.12s; }
.delay-2 { animation-delay: 0.26s; }

/* ── Top bar ── */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 100rpx 60rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-mark {
  position: relative;
  width: 56rpx;
  height: 56rpx;
}

.logo-ring {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid var(--ob-pink);
}

.logo-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--ob-pink);
}

.logo-top-dot {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--ob-pink-soft);
}

.lang-btn {
  min-width: 88rpx;
  min-height: 52rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--ob-muted);
  background: transparent;
  border: none;
}

.lang-btn::after { border: none; }

/* ── Page containers ── */
.page {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
}

/* ── Hero page ── */
.hero-page {
  align-items: center;
  justify-content: center;
  padding: 180rpx 72rpx 380rpx;
}

.hero-circle {
  position: relative;
  width: 440rpx;
  height: 440rpx;
  margin-bottom: 88rpx;
}

.circle-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 520rpx;
  height: 520rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #FFD6DF 0%, transparent 70%);
  animation: ringPulse 4s ease-in-out infinite;
}

.circle-white {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: var(--ob-white);
  box-shadow: 0 16rpx 96rpx rgba(255, 77, 106, 0.1);
}

.circle-dash {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 344rpx;
  height: 344rpx;
  border-radius: 50%;
  border: 2rpx dashed var(--ob-pink-pale);
}

.circle-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-icon {
  font-size: 64rpx;
}

.orbit-dot {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  animation: dotOrbit 14s linear infinite;
}

.orbit-dot::after {
  content: '';
  display: block;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--ob-pink);
  opacity: 0.35;
  transform: translate(-50%, -50%);
}

.hero-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.hero-line {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--ob-ink);
  line-height: 1.5;
  text-align: center;
}

.hero-pink {
  color: var(--ob-pink);
}

.hero-sub {
  font-size: 28rpx;
  color: var(--ob-sub);
  letter-spacing: 6rpx;
  text-align: center;
  font-weight: 300;
}

/* ── Features page ── */
.feature-page {
  justify-content: center;
  padding: 200rpx 64rpx 380rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--ob-ink);
  line-height: 1.4;
  margin-bottom: 72rpx;
}

.feature-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.feature-card {
  display: flex;
  align-items: center;
  gap: 36rpx;
  background: var(--ob-white);
  border-radius: 36rpx;
  padding: 40rpx 44rpx;
  box-shadow: 0 4rpx 32rpx rgba(0,0,0,0.03);
  border: 2rpx solid var(--ob-divider);
}

.feature-icon-wrap {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: var(--ob-pink-mist);
  display: flex;
  align-items: center;
  justify-content: center;
}

.feature-icon {
  font-size: 44rpx;
}

.feature-label {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ob-ink);
}

/* ── Trust page ── */
.trust-page {
  justify-content: center;
  padding: 200rpx 64rpx 380rpx;
}

.trust-card {
  background: linear-gradient(160deg, var(--ob-pink-mist), var(--ob-pink-pale));
  border-radius: 44rpx;
  padding: 56rpx 52rpx;
}

.trust-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.trust-row:last-child {
  margin-bottom: 0;
}

.trust-item {
  flex: 1;
  background: rgba(255,255,255,0.75);
  border-radius: 32rpx;
  padding: 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20rpx;
}

.trust-emoji {
  font-size: 48rpx;
}

.trust-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--ob-ink);
  line-height: 1.45;
  letter-spacing: 1rpx;
}

/* ── Bottom bar ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 0 68rpx;
  padding-bottom: calc(92rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, var(--ob-bg) 65%, transparent);
}

.pink-btn {
  position: relative;
  width: 100%;
  min-height: 112rpx;
  border-radius: 104rpx;
  background: linear-gradient(135deg, var(--ob-pink), var(--ob-pink-soft));
  box-shadow: 0 20rpx 72rpx rgba(255, 77, 106, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: none;
  padding: 0;
}

.pink-btn::after { border: none; }

.btn-shimmer {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
  animation: shimmer 3.5s ease-in-out infinite;
}

.btn-text {
  position: relative;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.bottom-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
  padding: 0 4rpx;
}

.skip-btn {
  font-size: 26rpx;
  color: var(--ob-muted);
  letter-spacing: 2rpx;
  padding: 20rpx 0;
  min-width: 88rpx;
}

.skip-placeholder {
  width: 88rpx;
}

.pip-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.pip {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--ob-muted);
  transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
}

.pip-on {
  width: 48rpx;
  border-radius: 6rpx;
  background: var(--ob-pink);
}

.footer-note {
  text-align: center;
  font-size: 22rpx;
  color: var(--ob-muted);
  margin-top: 16rpx;
  letter-spacing: 4rpx;
}
