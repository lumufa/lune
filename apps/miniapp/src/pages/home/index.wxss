.home-screen {
  gap: 32rpx;
}

/* ── Top bar ── */
.top-bar {
  min-height: 88rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.avatar-badge {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
}

.date-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date-text {
  color: var(--ink);
  font-size: 40rpx;
  line-height: 48rpx;
  font-weight: 700;
}

.calendar-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calendar-button:active {
  background: var(--surface-sunken);
}

.calendar-icon {
  font-size: 36rpx;
  line-height: 36rpx;
}

/* ── Hero panel ── */
.hero-panel {
  position: relative;
  border-radius: 112rpx;
  overflow: hidden;
  background: var(--pink-mist);
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.hero-glow-large {
  position: absolute;
  width: 560rpx;
  height: 560rpx;
  border-radius: 280rpx;
  background: rgba(255, 255, 255, 0.30);
  top: 48rpx;
  left: -160rpx;
}

.hero-glow-small {
  position: absolute;
  width: 440rpx;
  height: 440rpx;
  border-radius: 220rpx;
  background: rgba(255, 255, 255, 0.42);
  top: -60rpx;
  right: -80rpx;
}

.ring-outer {
  position: relative;
  width: 300rpx;
  height: 300rpx;
  border-radius: 150rpx;
  border: 10rpx solid var(--pink-pale);
  background: var(--surface);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.ring-accent {
  position: absolute;
  top: -10rpx;
  left: -10rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 150rpx;
  border: 14rpx solid transparent;
  border-top-color: rgba(255, 77, 106, 0.32);
  border-right-color: rgba(255, 77, 106, 0.32);
  transform: rotate(16deg);
  opacity: 0.65;
}

.ring-inner {
  width: 252rpx;
  height: 252rpx;
  border-radius: 126rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 0 12rpx;
}

.ring-top-caption {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 500;
}

.ring-value {
  color: var(--accent);
  font-size: 84rpx;
  line-height: 96rpx;
  font-weight: 800;
}

.ring-sub {
  color: var(--ink-body);
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
}

.ring-sub-warn {
  color: var(--warning);
}

.empty-copy {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 500;
  text-align: center;
}

.hero-subtle {
  color: var(--ink-body);
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.hero-btn {
  min-width: 320rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 48rpx;
  border-radius: 44rpx;
  background: var(--accent);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  margin: 0;
  border: none;
  box-shadow: var(--shadow-cta);
}

.hero-btn::after {
  border: none;
}

.hero-btn-secondary {
  background: var(--surface);
  color: var(--accent-deep);
  box-shadow: none;
}

/* ── Summary card ── */
.summary-card {
  border-radius: 48rpx;
  background: var(--surface);
  border: 1rpx solid var(--line-strong);
  overflow: hidden;
}

.summary-head {
  min-height: 84rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--line-strong);
}

.summary-title {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.summary-action {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-arrow {
  color: var(--muted);
  font-size: 28rpx;
  line-height: 28rpx;
}

.summary-grid {
  display: flex;
  flex-direction: row;
  padding: 32rpx 0;
}

.summary-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.summary-cell-value {
  color: var(--ink);
  font-size: 44rpx;
  line-height: 52rpx;
  font-weight: 700;
}

.summary-cell-unit {
  color: var(--muted);
  font-size: 22rpx;
  font-weight: 500;
}

.summary-cell-label {
  color: var(--ink-body);
  font-size: 24rpx;
  font-weight: 500;
  margin-top: 4rpx;
}

/* ── Recent card ── */
.recent-card {
  border-radius: 48rpx;
  background: var(--surface);
  border: 1rpx solid var(--line-strong);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.recent-title {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
}

.recent-date {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 600;
}

.recent-meta {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 0 32rpx;
  min-height: 52rpx;
  border-radius: 26rpx;
  background: var(--pink-mist);
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-label {
  color: var(--accent-deep);
  font-size: 24rpx;
  line-height: 24rpx;
  font-weight: 600;
}
