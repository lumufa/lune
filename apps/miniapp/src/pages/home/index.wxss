.home-screen {
  background: var(--flo-canvas);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 0;
}

.brand-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
}

.date-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.date-text {
  color: var(--flo-ink);
  font-size: 52rpx;
  font-weight: 700;
}

.date-hint {
  color: var(--flo-muted);
  font-size: 24rpx;
  font-weight: 500;
}

.calendar-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calendar-icon {
  font-size: 44rpx;
}

/* Hero Panel */
.hero-panel {
  position: relative;
  border-radius: 56rpx;
  overflow: hidden;
  background: var(--flo-hero);
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
}

.hero-glow-large {
  position: absolute;
  width: 720rpx;
  height: 720rpx;
  border-radius: 360rpx;
  background: rgba(255, 255, 255, 0.30);
  top: 64rpx;
  left: -220rpx;
}

.hero-glow-small {
  position: absolute;
  width: 560rpx;
  height: 560rpx;
  border-radius: 280rpx;
  background: rgba(255, 255, 255, 0.42);
  top: -76rpx;
  right: -116rpx;
}

.ring-outer {
  position: relative;
  width: 440rpx;
  height: 440rpx;
  border-radius: 220rpx;
  border: 12rpx solid #FBE6EE;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.ring-accent {
  position: absolute;
  top: -12rpx;
  left: -12rpx;
  width: 440rpx;
  height: 440rpx;
  border-radius: 220rpx;
  border: 16rpx solid transparent;
  border-top-color: rgba(255, 91, 141, 0.42);
  border-right-color: rgba(255, 91, 141, 0.42);
  transform: rotate(16deg);
  opacity: 0.65;
}

.ring-inner {
  width: 368rpx;
  height: 368rpx;
  border-radius: 184rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.ring-caption {
  color: #7F808B;
  font-size: 28rpx;
  font-weight: 500;
}

.ring-value {
  color: var(--flo-pink);
  font-size: 112rpx;
  line-height: 124rpx;
  font-weight: 800;
}

.empty-copy {
  color: #8A8B95;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  padding: 0 32rpx;
}

/* Hero copy */
.hero-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.hero-title {
  color: var(--flo-ink);
  font-size: 48rpx;
  line-height: 60rpx;
  font-weight: 700;
  text-align: center;
}

.hero-value {
  color: var(--flo-pink);
  font-size: 80rpx;
  line-height: 92rpx;
  font-weight: 800;
}

.hero-value-warning {
  color: #F2A94A;
}

.hero-subtle {
  color: #616270;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

/* Hero buttons */
.hero-btn {
  width: 100%;
  min-height: 104rpx;
  border-radius: 52rpx;
  background: var(--flo-pink);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 104rpx;
}

.hero-btn::after {
  border: none;
}

.secondary-hero-btn {
  background: #ffffff;
  color: var(--accent-deep);
}

/* Summary card */
.summary-card {
  border-radius: 40rpx;
  background: #ffffff;
  border: 2rpx solid var(--flo-border);
  overflow: hidden;
}

.summary-head {
  min-height: 108rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--flo-border);
}

.summary-title {
  color: var(--flo-ink);
  font-size: 36rpx;
  font-weight: 700;
}

.summary-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-arrow {
  color: var(--flo-muted);
  font-size: 36rpx;
}

.summary-row {
  min-height: 108rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-row-border {
  border-bottom: 1rpx solid var(--flo-border);
}

.summary-label {
  color: #5B5D67;
  font-size: 30rpx;
  font-weight: 500;
}

.summary-value {
  color: var(--flo-ink);
  font-size: 30rpx;
  font-weight: 700;
}
