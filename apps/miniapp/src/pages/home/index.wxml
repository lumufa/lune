<view class="screen home-screen">
  <view class="top-bar">
    <view class="avatar-badge">
      <image class="brand-avatar" src="/assets/haven-icon.png" mode="aspectFill" />
    </view>
    <view class="date-block">
      <text class="date-text">{{todayLabel}}</text>
    </view>
    <view class="calendar-button" bindtap="openCalendar">
      <text class="calendar-icon">📅</text>
    </view>
  </view>

  <view class="hero-panel">
    <view class="hero-glow-large"></view>
    <view class="hero-glow-small"></view>

    <view class="ring-outer">
      <view class="ring-accent"></view>
      <view class="ring-inner">
        <block wx:if="{{hasCycleInfo}}">
          <text class="ring-top-caption">{{copy.cycleDayLabel}}</text>
          <text class="ring-value">{{cycleDay}}</text>
          <text class="ring-sub {{isLate ? 'ring-sub-warn' : ''}}" wx:if="{{ringSubText}}">{{ringSubText}}</text>
        </block>
        <text class="empty-copy" wx:else>{{copy.emptyMessage}}</text>
      </view>
    </view>

    <text class="hero-subtle" wx:if="{{predictedDate}}">{{copy.predictedDatePrefix}}{{predictedDate}}</text>

    <button class="hero-btn {{todayRecordId ? 'hero-btn-secondary' : ''}}" bindtap="openLog">
      {{todayRecordId ? copy.editTodayLog : copy.logToday}}
    </button>
  </view>

  <view class="summary-card">
    <view class="summary-head">
      <text class="summary-title">{{copy.cycleSummary}}</text>
      <view class="summary-action" bindtap="openCalendar">
        <text class="summary-arrow">→</text>
      </view>
    </view>
    <view class="summary-grid">
      <view class="summary-cell">
        <text class="summary-cell-value">{{averageCycleLength}}</text>
        <text class="summary-cell-unit">{{copy.dayUnit}}</text>
        <text class="summary-cell-label">{{copy.averageCycle}}</text>
      </view>
      <view class="summary-cell">
        <text class="summary-cell-value">{{averagePeriodLength}}</text>
        <text class="summary-cell-unit">{{copy.dayUnit}}</text>
        <text class="summary-cell-label">{{copy.averagePeriod}}</text>
      </view>
      <view class="summary-cell">
        <text class="summary-cell-value">{{recordCount}}</text>
        <text class="summary-cell-unit">{{copy.logCountUnit}}</text>
        <text class="summary-cell-label">{{copy.logCount}}</text>
      </view>
    </view>
  </view>

  <view class="recent-card" wx:if="{{recentEntry}}" bindtap="openRecentLog">
    <view class="recent-head">
      <text class="recent-title">{{copy.recentEntryTitle}}</text>
      <text class="recent-date">{{recentEntry.dateLabel}}</text>
    </view>
    <view class="recent-meta">
      <view class="chip"><text class="chip-label">{{recentEntry.flowLabel}}</text></view>
      <view class="chip"><text class="chip-label">{{recentEntry.moodLabel}}</text></view>
      <view class="chip" wx:if="{{recentEntry.symptomsLabel}}"><text class="chip-label">{{recentEntry.symptomsLabel}}</text></view>
    </view>
  </view>
</view>
