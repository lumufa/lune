.calendar-screen {
  background: var(--flo-canvas);
  gap: 36rpx;
}

.toolbar {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 48rpx;
  color: var(--flo-ink);
  font-weight: 600;
}

.header-copy {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.header-title {
  color: var(--flo-ink);
  font-size: 44rpx;
  font-weight: 700;
}

.header-subtle {
  color: var(--flo-muted);
  font-size: 24rpx;
  font-weight: 500;
}

/* Calendar card */
.calendar-card {
  border-radius: 48rpx;
  background: #ffffff;
  padding: 32rpx 20rpx 24rpx;
}

.week-row {
  display: flex;
  margin-bottom: 24rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  color: #B0B1BB;
  font-size: 24rpx;
  font-weight: 600;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 28rpx;
}

.day-wrap {
  width: 14.2857%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-cell {
  width: 80rpx;
  height: 80rpx;
}

.day-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-label {
  color: #676975;
  font-size: 30rpx;
  font-weight: 500;
}

.today-button {
  background: #F0F1F5;
}

.today-label {
  color: #101115;
  font-weight: 700;
}

.period-button {
  background: var(--flo-pink);
}

.period-label {
  color: #ffffff;
  font-weight: 700;
}

.predicted-button {
  border: 4rpx solid var(--flo-pink-border);
}

.predicted-label {
  color: var(--flo-pink);
}

.dot-area {
  margin-top: 8rpx;
  height: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.symptom-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #7C8CF4;
}

/* Legend */
.legend-card {
  border-radius: 36rpx;
  background: #FFF5F7;
  border: 2rpx solid #FFE2E8;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.legend-title {
  color: var(--flo-ink);
  font-size: 28rpx;
  font-weight: 700;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
}

.legend-dot-period {
  background: var(--flo-pink);
}

.legend-dot-predicted {
  border: 4rpx solid var(--flo-pink-border);
}

.legend-dot-symptom {
  background: #7C8CF4;
}

.legend-text {
  color: #5B5D67;
  font-size: 24rpx;
  font-weight: 500;
}
