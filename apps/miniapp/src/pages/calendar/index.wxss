.calendar-screen {
  gap: 20rpx;
  padding-bottom: 200rpx;
}

/* ── Status bar with mini ring ── */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 28rpx 16rpx 16rpx;
  border-radius: 40rpx;
  background: var(--pink-mist);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

.status-bar-empty {
  justify-content: center;
  padding: 20rpx 28rpx;
}

.status-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* Mini ring */
.mini-ring {
  position: relative;
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-ring-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  border: 6rpx solid var(--pink-pale);
  box-sizing: border-box;
}

.mini-ring-arc {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 50%;
  border: 6rpx solid transparent;
  border-top-color: var(--accent);
  border-right-color: var(--accent);
  box-sizing: border-box;
  transform: rotate(-90deg);
}

.mini-ring-num {
  position: relative;
  color: var(--accent);
  font-size: 32rpx;
  font-weight: 800;
  z-index: 1;
}

.status-text {
  color: var(--ink);
  font-size: 26rpx;
  font-weight: 600;
}

.status-predict {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 500;
}

/* ── Month navigation ── */
.month-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: var(--surface);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
}

.month-arrow {
  font-size: 40rpx;
  color: var(--ink);
  font-weight: 600;
}

.month-label {
  color: var(--ink);
  font-size: 36rpx;
  font-weight: 700;
}

/* ── Calendar grid card ── */
.cal-card {
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  box-shadow: var(--shadow-card);
  padding: 24rpx 16rpx 16rpx;
}

.week-row {
  display: flex;
  margin-bottom: 16rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  color: var(--muted-2);
  font-size: 22rpx;
  font-weight: 600;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  row-gap: 12rpx;
}

.day-wrap {
  width: 14.2857%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-cell {
  width: 72rpx;
  height: 72rpx;
}

.day-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.1s;
}

.day-btn-hover {
  transform: scale(0.9);
  opacity: 0.8;
}

.day-num {
  color: var(--ink-2);
  font-size: 28rpx;
  font-weight: 500;
}

.day-today {
  background: var(--pink-mist);
}

.day-num-today {
  color: var(--ink);
  font-weight: 700;
}

.day-period {
  background: var(--accent);
}

.day-num-period {
  color: #ffffff;
  font-weight: 700;
}

.day-predicted {
  border: 3rpx dashed var(--pink-border);
}

.day-num-predicted {
  color: var(--accent);
}

.dot-row {
  margin-top: 4rpx;
  height: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.symptom-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #7C8CF4;
}

/* ── Inline legend ── */
.legend-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  padding: 16rpx 0 4rpx;
  border-top: 1rpx solid var(--divider);
  margin-top: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
}

.dot-period {
  background: var(--accent);
}

.dot-predicted {
  border: 2rpx dashed var(--pink-border);
}

.dot-symptom {
  background: #7C8CF4;
}

.legend-text {
  color: var(--muted);
  font-size: 20rpx;
  font-weight: 500;
}

/* ── Bottom spacer ── */
.bottom-spacer {
  height: 40rpx;
}

/* ── Floating CTA ── */
.float-cta-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 48rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom) + 100rpx);
  background: linear-gradient(0deg, var(--bg) 60%, transparent);
  z-index: 100;
}

.float-cta {
  width: 100%;
  min-height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--accent), var(--pink-soft));
  box-shadow: 0 16rpx 48rpx rgba(255, 77, 106, 0.3);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.float-cta::after {
  border: none;
}
