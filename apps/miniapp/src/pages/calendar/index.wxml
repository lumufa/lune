<view class="screen calendar-screen">

  <!-- Status bar with mini ring -->
  <view class="status-bar" wx:if="{{hasRecords && hasNextPeriod}}">
    <view class="status-left">
      <view class="mini-ring">
        <view class="mini-ring-bg"></view>
        <view class="mini-ring-arc" style="--progress: {{cycleProgress}};"></view>
        <text class="mini-ring-num">{{cycleDay}}</text>
      </view>
      <text class="status-text">{{isLate ? copy.periodLate : (copy.untilNextPeriod + daysUntilNext + copy.dayUnit)}}</text>
    </view>
    <text class="status-predict">{{copy.predictedShort}}{{predictedDate}}</text>
  </view>

  <view class="status-bar status-bar-empty" wx:if="{{!hasRecords}}">
    <text class="status-text">{{copy.waitingFirstRecord}}</text>
  </view>

  <!-- Month navigation -->
  <view class="month-bar">
    <view class="month-nav" bindtap="prevMonth">
      <text class="month-arrow">‹</text>
    </view>
    <text class="month-label">{{monthLabel}}</text>
    <view class="month-nav" bindtap="nextMonth">
      <text class="month-arrow">›</text>
    </view>
  </view>

  <!-- Calendar grid -->
  <view class="cal-card">
    <view class="week-row">
      <text class="week-day" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="grid">
      <view wx:for="{{calendarDays}}" wx:key="key" class="day-wrap">
        <view wx:if="{{item.isEmpty}}" class="empty-cell"></view>
        <view
          wx:else
          class="day-btn {{item.isToday ? 'day-today' : ''}} {{item.isPeriod ? 'day-period' : ''}} {{item.isPredicted ? 'day-predicted' : ''}}"
          data-date-key="{{item.dateKey}}"
          data-record-id="{{item.recordId}}"
          bindtap="openDate"
          hover-class="day-btn-hover"
        >
          <text class="day-num {{item.isToday ? 'day-num-today' : ''}} {{item.isPeriod ? 'day-num-period' : ''}} {{item.isPredicted ? 'day-num-predicted' : ''}}">{{item.day}}</text>
        </view>
        <view class="dot-row">
          <view wx:if="{{item.hasSymptoms && !item.isPeriod}}" class="symptom-dot"></view>
        </view>
      </view>
    </view>

    <!-- Inline legend -->
    <view class="legend-inline">
      <view class="legend-item">
        <view class="legend-dot dot-period"></view>
        <text class="legend-text">{{copy.legendPeriod}}</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot dot-predicted"></view>
        <text class="legend-text">{{copy.legendPredicted}}</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot dot-symptom"></view>
        <text class="legend-text">{{copy.legendSymptom}}</text>
      </view>
    </view>
  </view>

  <!-- Bottom spacer -->
  <view class="bottom-spacer"></view>
</view>

<!-- Floating CTA -->
<view class="float-cta-wrap">
  <button class="float-cta" bindtap="openLog">
    {{todayRecordId ? copy.editTodayLog : copy.logToday}}
  </button>
</view>
