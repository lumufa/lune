.lang-btn {
  min-width: 96rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-block {
  padding: 0 4rpx 12rpx;
}

.time-value {
  display: block;
  margin-top: 12rpx;
  color: var(--ink);
  font-size: 64rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.setting-card {
  padding: 8rpx 32rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.setting-row:last-child {
  border-bottom: none;
}

.field-label {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 500;
}

.picker-field {
  min-width: 160rpx;
  padding: 14rpx 24rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
}

.reminder-panel {
  padding: 8rpx 32rpx;
}

.reminder-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.reminder-left {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-width: 0;
  flex: 1;
}

.reminder-icon {
  font-size: 36rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.reminder-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reminder-title {
  display: block;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.3;
}

.reminder-detail {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.5;
}

.save-btn {
  margin-top: 32rpx;
}

.back-btn {
  margin-top: 16rpx;
}
