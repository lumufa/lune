.screen {
  background: var(--flo-canvas);
}

.lang-btn {
  min-width: 96rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  color: var(--flo-ink);
  font-size: 48rpx;
  font-weight: 700;
}

.header-subtle {
  color: var(--flo-muted);
  font-size: 28rpx;
  font-weight: 500;
}

.record-card {
  border-radius: 40rpx;
  background: #ffffff;
  border: 2rpx solid #EFEFF3;
  padding: 36rpx;
}

.form-stack {
  gap: 28rpx;
}

.section-block {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 18rpx;
}

.card-title {
  color: var(--flo-ink);
  font-size: 34rpx;
  font-weight: 700;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-meta {
  color: var(--flo-muted);
  font-size: 24rpx;
  font-weight: 600;
}

.field-label {
  color: #8A8B95;
  font-size: 24rpx;
  font-weight: 600;
}

.datetime-row {
  display: flex;
  gap: 24rpx;
}

.date-field {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.input-field {
  min-height: 96rpx;
  border-radius: 28rpx;
  background: #F5F5F7;
  padding: 0 28rpx;
  color: var(--flo-ink);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.datetime-picker {
  flex: 1;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  background: #F5F5F7;
  color: var(--flo-ink);
  font-size: 30rpx;
  font-weight: 600;
}

.flow-grid {
  display: flex;
  gap: 20rpx;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.symptom-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.symptom-item {
  width: 30.5%;
  min-height: 164rpx;
  border-radius: 32rpx;
  border: 2rpx solid #E3E4EA;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.symptom-item-active {
  border-color: #FFD6E2;
  background: #FFF1F5;
}

.symptom-label {
  color: #5B5D67;
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
}

.symptom-label-active {
  color: var(--flo-pink);
  font-weight: 600;
}

.mood-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.mood-chip {
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 38rpx;
  background: #F3F4F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mood-chip-active {
  background: #FFE7EE;
}

.mood-label {
  color: #5B5D67;
  font-size: 28rpx;
  font-weight: 600;
}

.mood-label-active {
  color: var(--flo-pink);
}

.choice-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  padding: 0 20rpx;
  border-radius: 28rpx;
  border: 2rpx solid #E3E4EA;
  background: #ffffff;
  color: #5B5D67;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
}

.flow-chip {
  flex: 1;
  min-width: 0;
}

.block-chip {
  width: 100%;
}

.choice-chip-active {
  border-color: #F7C9D6;
  background: #FFF1F5;
  color: var(--flo-pink);
  font-weight: 600;
}

.field-action-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.pain-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pain-summary {
  display: block;
  color: var(--flo-pink);
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.2;
}

.pain-guide-btn {
  min-height: 60rpx;
  line-height: 60rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.pain-slider {
  margin: 12rpx 0 4rpx;
}

.pain-description {
  display: block;
  color: #8A8B95;
  line-height: 1.55;
  font-size: 26rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #F5F5F7;
  color: var(--flo-ink);
  font-size: 30rpx;
  line-height: 1.55;
  box-sizing: border-box;
  border: none;
}

.save-btn {
  width: 100%;
  min-height: 112rpx;
  border-radius: 36rpx;
  background: #111217;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 112rpx;
  margin-top: 8rpx;
}

.save-btn::after {
  border: none;
}

.delete-btn {
  margin-top: 16rpx;
}
