.record-screen {
  gap: 20rpx;
  padding-bottom: 280rpx;
}

/* ── Cards ── */
.rec-card {
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  box-shadow: var(--shadow-card);
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-label {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 700;
}

.sub-label {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 600;
}

.mt16 {
  margin-top: 8rpx;
}

/* ── Date inline ── */
.date-inline {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 80rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-md);
  background: var(--surface-sunken);
}

.date-val {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
}

.date-arrow {
  color: var(--muted-2);
  font-size: 28rpx;
}

/* ── Flow chips (equal width) ── */
.chip-row {
  display: flex;
  gap: 16rpx;
}

.chip {
  flex: 1;
  min-height: 72rpx;
  border-radius: 36rpx;
  background: #F5F5F5;
  color: var(--ink-2);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-active {
  background: var(--pink-pale);
  color: var(--accent);
}

/* ── Pain chips ── */
.pain-chip {
  flex: 1;
  min-height: 80rpx;
  border-radius: 36rpx;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.pain-chip-active {
  background: var(--pink-pale);
}

.pain-num {
  color: var(--ink-2);
  font-size: 30rpx;
  font-weight: 700;
}

.pain-chip-active .pain-num {
  color: var(--accent);
}

.pain-hint {
  color: var(--muted);
  font-size: 18rpx;
  font-weight: 500;
}

.pain-chip-active .pain-hint {
  color: var(--accent);
  opacity: 0.7;
}

.pain-desc {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 36rpx;
}

/* ── Tags (unified symptom + mood chips) ── */
.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 34rpx;
  background: #F5F5F5;
  color: var(--ink-2);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-active {
  background: var(--pink-pale);
  color: var(--accent);
}

/* ── Textarea ── */
.textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--surface-sunken);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  border: none;
}

/* ── Bottom spacer ── */
.btn-spacer {
  height: 60rpx;
}

/* ── Fixed save button ── */
.fixed-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 48rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, var(--bg) 70%, transparent);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.save-btn {
  width: 100%;
  min-height: 100rpx;
  border-radius: 50rpx;
  background: var(--accent);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.save-btn::after {
  border: none;
}

.delete-link-wrap {
  padding: 8rpx 0 4rpx;
}

.delete-link {
  color: #E53E3E;
  font-size: 24rpx;
  font-weight: 500;
  opacity: 0.5;
}
