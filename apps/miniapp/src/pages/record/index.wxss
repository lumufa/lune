.record-screen {
  gap: 20rpx;
  padding-bottom: 280rpx;
}

/* ── Cards ── */
.rec-card {
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  box-shadow: var(--shadow-card);
  padding: 28rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-label {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 700;
}

.sub-label {
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 600;
}

.mt16 {
  margin-top: 8rpx;
}

/* ── Date inline ── */
.date-inline {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 80rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-md);
  background: var(--surface-sunken);
}

.date-tap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
}

.date-val {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 600;
}

.date-arrow {
  color: var(--muted-2);
  font-size: 28rpx;
}

/* ── Date picker sheet ── */
.date-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
  z-index: 200;
}

.date-sheet-mask-on {
  opacity: 1;
  pointer-events: auto;
}

.date-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.25s ease;
  z-index: 201;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.date-sheet-on {
  transform: translateY(0);
}

.date-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.date-sheet-title {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.date-sheet-btn {
  color: var(--muted);
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

.date-sheet-btn-primary {
  color: var(--accent);
  font-weight: 700;
}

.date-picker-view {
  width: 100%;
  height: 440rpx;
}

.date-picker-indicator {
  height: 80rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.date-picker-mask {
  background: linear-gradient(180deg, var(--surface) 0%, rgba(255, 255, 255, 0) 40%, rgba(255, 255, 255, 0) 60%, var(--surface) 100%);
}

.date-picker-item {
  text-align: center;
  line-height: 80rpx;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 500;
}

/* ── Flow chips (equal width) ── */
.chip-row {
  display: flex;
  gap: 16rpx;
}

.chip {
  flex: 1;
  min-height: 72rpx;
  border-radius: 36rpx;
  background: #F5F5F5;
  color: var(--ink-2);
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-active {
  background: var(--pink-pale);
  color: var(--accent);
}

/* ── Pain chips ── */
.pain-chip {
  flex: 1;
  min-height: 80rpx;
  border-radius: 36rpx;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}

.pain-chip-active {
  background: var(--pink-pale);
}

.pain-num {
  color: var(--ink-2);
  font-size: 30rpx;
  font-weight: 700;
}

.pain-chip-active .pain-num {
  color: var(--accent);
}

.pain-hint {
  color: var(--muted);
  font-size: 18rpx;
  font-weight: 500;
}

.pain-chip-active .pain-hint {
  color: var(--accent);
  opacity: 0.7;
}

.pain-desc {
  color: var(--muted);
  font-size: 24rpx;
  line-height: 36rpx;
}

/* ── Tags (unified symptom + mood chips) ── */
.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  height: 68rpx;
  padding: 0 24rpx;
  border-radius: 34rpx;
  background: #F5F5F5;
  color: var(--ink-2);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tag-active {
  background: var(--pink-pale);
  color: var(--accent);
}

/* ── Textarea ── */
.textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  border-radius: var(--radius-md);
  background: var(--surface-sunken);
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
  border: none;
}

/* ── Bottom spacer ── */
.btn-spacer {
  height: 60rpx;
}

/* ── Fixed save button ── */
.fixed-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 48rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, var(--bg) 70%, transparent);
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.save-btn {
  width: 100%;
  min-height: 100rpx;
  border-radius: 50rpx;
  background: var(--accent);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.save-btn::after {
  border: none;
}

.delete-link-wrap {
  padding: 8rpx 0 4rpx;
}

.delete-link {
  color: #E53E3E;
  font-size: 24rpx;
  font-weight: 500;
  opacity: 0.5;
}
