<view class="screen record-screen">
  <text class="page-title">{{isEditMode ? copy.titleEdit : copy.titleCreate}}</text>

  <!-- Date card: compact one-line -->
  <view class="rec-card">
    <text class="card-label">{{copy.dateLabel}}</text>
    <view class="date-inline">
      <view class="date-tap" data-target="start" bindtap="openDatePicker">
        <text class="date-val">{{startDatePart}}</text>
      </view>
      <text class="date-arrow">→</text>
      <view class="date-tap" data-target="end" bindtap="openDatePicker">
        <text class="date-val">{{endDatePart}}</text>
      </view>
    </view>
  </view>

  <!-- Body card: flow + pain -->
  <view class="rec-card">
    <text class="card-label">{{copy.bodyLabel}}</text>

    <text class="sub-label">{{copy.flowLabel}}</text>
    <view class="chip-row">
      <view
        class="chip {{flowLevel === item.value ? 'chip-active' : ''}}"
        wx:for="{{flowItems}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="selectFlow"
      >{{item.label}}</view>
    </view>

    <text class="sub-label mt16">{{copy.painLabel}}</text>
    <view class="chip-row">
      <view
        class="pain-chip {{painLevel === item.value ? 'pain-chip-active' : ''}}"
        wx:for="{{painItems}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="selectPain"
      >
        <text class="pain-num">{{item.label}}</text>
        <text class="pain-hint">{{item.hint}}</text>
      </view>
    </view>
    <text class="pain-desc" wx:if="{{painDescription}}">{{painDescription}}</text>
  </view>

  <!-- Feeling card: symptoms + mood -->
  <view class="rec-card">
    <text class="card-label">{{copy.feelingLabel}}</text>

    <text class="sub-label">{{copy.symptomsLabel}}</text>
    <view class="tag-wrap">
      <view
        class="tag {{item.selected ? 'tag-active' : ''}}"
        wx:for="{{symptomItems}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="toggleSymptom"
      >{{item.label}}</view>
    </view>

    <text class="sub-label mt16">{{copy.moodLabel}}</text>
    <view class="tag-wrap">
      <view
        class="tag {{mood === item.value ? 'tag-active' : ''}}"
        wx:for="{{moodItems}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="selectMood"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- Notes card -->
  <view class="rec-card">
    <text class="card-label">{{copy.noteLabel}}</text>
    <textarea
      class="textarea"
      maxlength="200"
      placeholder="{{copy.notePlaceholder}}"
      placeholder-style="color: #B0B1BB;"
      bindinput="changeNote"
      value="{{note}}"
    />
  </view>

  <!-- Bottom spacer for fixed button -->
  <view class="btn-spacer"></view>
</view>

<!-- Date picker sheet -->
<view class="date-sheet-mask {{pickerVisible ? 'date-sheet-mask-on' : ''}}" bindtap="cancelDatePicker" catchtouchmove="noop"></view>
<view class="date-sheet {{pickerVisible ? 'date-sheet-on' : ''}}">
  <view class="date-sheet-head">
    <text class="date-sheet-btn" bindtap="cancelDatePicker">{{copy.cancelLabel}}</text>
    <text class="date-sheet-title">{{pickerTarget === 'start' ? copy.startDateTitle : copy.endDateTitle}}</text>
    <text class="date-sheet-btn date-sheet-btn-primary" bindtap="confirmDatePicker">{{copy.confirmLabel}}</text>
  </view>
  <picker-view class="date-picker-view" value="{{pickerIndex}}" indicator-class="date-picker-indicator" mask-class="date-picker-mask" bindchange="onDatePickerChange">
    <picker-view-column>
      <view class="date-picker-item" wx:for="{{pickerYears}}" wx:key="*this">{{item}}{{copy.yearUnit}}</view>
    </picker-view-column>
    <picker-view-column>
      <view class="date-picker-item" wx:for="{{pickerMonths}}" wx:key="*this">{{item}}{{copy.monthUnit}}</view>
    </picker-view-column>
    <picker-view-column>
      <view class="date-picker-item" wx:for="{{pickerDays}}" wx:key="*this">{{item}}{{copy.dayOfMonthUnit}}</view>
    </picker-view-column>
  </picker-view>
</view>

<!-- Fixed save button -->
<view class="fixed-btn-wrap">
  <button class="save-btn" loading="{{isSubmitting}}" bindtap="submitRecord">{{copy.saveLabel}}</button>
  <view class="delete-link-wrap" wx:if="{{isEditMode}}" bindtap="deleteCurrentRecord">
    <text class="delete-link">{{copy.deleteLabel}}</text>
  </view>
</view>
