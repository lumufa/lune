page {
  --bg: #FBF8F9;
  --surface: #ffffff;
  --surface-sunken: #FFF5F7;
  --ink: #1E1E2C;
  --ink-2: #3C3C4A;
  --muted: #8C8C9A;
  --muted-2: #C4C4CE;
  --line: rgba(0, 0, 0, 0.04);
  --line-strong: rgba(0, 0, 0, 0.08);
  --accent: #FF4D6A;
  --accent-press: #E8445D;
  --accent-soft: rgba(255, 77, 106, 0.1);
  --accent-deep: #D14060;
  --danger: #d64a3b;
  --pink: #FF4D6A;
  --pink-soft: #FF6B82;
  --pink-pale: #FFE8EC;
  --pink-mist: #FFF5F7;
  --pink-border: #FFD6DF;
  --divider: rgba(0, 0, 0, 0.04);
  --radius-xl: 28rpx;
  --radius-lg: 24rpx;
  --radius-md: 20rpx;
  --radius-sm: 16rpx;
  --shadow-card: 0 2rpx 16rpx rgba(0, 0, 0, 0.02);
  background: var(--bg);
  color: var(--ink);
  min-height: 100%;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", "Segoe UI", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

.screen {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx 120rpx;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* ── Cards ── */
.card {
  box-sizing: border-box;
  padding: 36rpx;
  border-radius: 40rpx;
  background: var(--surface);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  box-shadow: var(--shadow-card);
}

/* ── Typography ── */
.page-title {
  display: block;
  color: var(--ink);
  font-size: 48rpx;
  line-height: 1.3;
  font-weight: 700;
}

.section-title {
  display: block;
  color: var(--ink);
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

/* ── Buttons ── */
.pink-btn {
  position: relative;
  width: 100%;
  min-height: 112rpx;
  border-radius: 104rpx;
  background: linear-gradient(135deg, var(--accent), var(--pink-soft));
  box-shadow: 0 20rpx 72rpx rgba(255, 77, 106, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: none;
  padding: 0;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.pink-btn::after { border: none; }

.dark-btn {
  width: 100%;
  min-height: 112rpx;
  border-radius: 36rpx;
  background: var(--ink);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 112rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.dark-btn::after { border: none; }

.ghost-btn {
  box-sizing: border-box;
  border: none;
  border-radius: 18rpx;
  min-height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 20rpx;
  color: var(--muted-2);
  background: transparent;
}

.ghost-btn::after { border: none; }

.danger-btn {
  box-sizing: border-box;
  border: none;
  border-radius: 18rpx;
  min-height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 32rpx;
  text-align: center;
  color: var(--danger);
  background: transparent;
  border: 1rpx solid rgba(214, 74, 59, 0.3);
}

.danger-btn::after { border: none; }

/* ── Layout helpers ── */
.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
