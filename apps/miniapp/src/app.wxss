page {
  --bg: #f4f4f6;
  --bg-dim: #ecebef;
  --surface: #ffffff;
  --surface-sunken: #f9f9fb;
  --ink: #111114;
  --ink-1: #1f1f24;
  --ink-2: #3c3c43;
  --muted: #7a7a80;
  --muted-2: #9a9aa0;
  --line: rgba(0, 0, 0, 0.06);
  --line-strong: rgba(0, 0, 0, 0.1);
  --accent: #FF5B8D;
  --accent-press: #FF4B81;
  --accent-soft: rgba(255, 91, 141, 0.1);
  --accent-deep: #D14A72;
  --danger: #d64a3b;
  --flo-canvas: #F4F4F6;
  --flo-hero: #D9E0F1;
  --flo-ink: #202028;
  --flo-muted: #8D8E97;
  --flo-border: #ECECF2;
  --flo-pink: #FF5B8D;
  --flo-pink-soft: #FFE8F0;
  --flo-pink-border: #F9B6C9;
  --teal: #4ECDC4;
  --radius-xl: 28rpx;
  --radius-lg: 24rpx;
  --radius-md: 20rpx;
  --radius-sm: 16rpx;
  --shadow-card: 0 2rpx 12rpx rgba(17, 17, 20, 0.04);
  --shadow-press: 0 4rpx 16rpx rgba(17, 17, 20, 0.06);
  background: var(--bg);
  color: var(--ink);
  min-height: 100%;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", "Segoe UI", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

.screen {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 32rpx 120rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  margin: 0 -8rpx 4rpx;
}

.toolbar.center-toolbar {
  justify-content: flex-end;
}

/* Cards */
.hero-card,
.panel,
.record-card,
.setting-card {
  position: relative;
  box-sizing: border-box;
  padding: 36rpx;
  border-radius: var(--radius-xl);
  background: var(--surface);
  border: 1rpx solid var(--line);
  box-shadow: var(--shadow-card);
}

/* Typography */
.page-title {
  display: block;
  color: var(--ink);
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.eyebrow {
  display: block;
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-title {
  display: block;
  margin-top: 14rpx;
  color: var(--ink);
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 28rpx;
  line-height: 1.55;
}

.section-title {
  display: block;
  margin: 12rpx 4rpx 4rpx;
  color: var(--ink-1);
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
}

.card-title {
  display: block;
  color: var(--ink);
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 600;
}

.muted {
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.5;
}

/* Metric */
.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
  margin-top: 28rpx;
}

.metric-card {
  padding: 24rpx 24rpx 26rpx;
  border-radius: var(--radius-md);
  background: var(--surface-sunken);
  border: 1rpx solid var(--line);
}

.metric-card .muted {
  font-size: 24rpx;
  color: var(--muted);
}

.metric-value {
  display: block;
  margin-top: 12rpx;
  color: var(--ink);
  font-size: 44rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

/* Buttons */
.button-row {
  display: flex;
  gap: 18rpx;
  margin-top: 32rpx;
}

.button-row button {
  flex: 1;
  min-width: 0;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  box-sizing: border-box;
  border: none;
  border-radius: 18rpx;
  min-height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 32rpx;
  text-align: center;
}

.primary-btn {
  color: #ffffff;
  background: var(--accent);
}

.primary-btn[disabled] {
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 91, 141, 0.5);
}

.secondary-btn {
  color: var(--ink);
  background: var(--surface-sunken);
  border: 1rpx solid var(--line-strong);
}

.ghost-btn {
  color: var(--ink-2);
  background: transparent;
  border: 1rpx solid var(--line-strong);
}

.danger-btn {
  color: var(--danger);
  background: transparent;
  border: 1rpx solid rgba(214, 74, 59, 0.3);
}

.primary-btn::after,
.secondary-btn::after,
.ghost-btn::after,
.danger-btn::after {
  border: none;
}

.primary-btn:active {
  background: var(--accent-press);
}

.secondary-btn:active,
.ghost-btn:active {
  background: rgba(0, 0, 0, 0.04);
}

/* Pills / tags */
.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: var(--surface-sunken);
  border: 1rpx solid var(--line);
  color: var(--ink-2);
  font-size: 24rpx;
  line-height: 1.4;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: var(--accent);
  font-size: 24rpx;
  line-height: 1.4;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* Layout helpers */
.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

/* Form inputs */
.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: var(--muted);
  font-size: 26rpx;
  font-weight: 500;
}

.text-input,
.textarea,
.picker-field {
  box-sizing: border-box;
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--line-strong);
  background: var(--surface-sunken);
  color: var(--ink);
  font-size: 30rpx;
  line-height: 1.35;
}

.textarea {
  min-height: 200rpx;
  line-height: 1.5;
}

/* List helpers */
.list-item {
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.list-item:last-child {
  border-bottom: none;
}

.empty-state {
  padding: 56rpx 32rpx;
  text-align: center;
  color: var(--muted);
  font-size: 28rpx;
}
